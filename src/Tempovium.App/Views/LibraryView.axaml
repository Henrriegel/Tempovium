<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tempovium.ViewModels"
             xmlns:controls="using:Tempovium.Controls"
             x:Class="Tempovium.Views.LibraryView"
             x:DataType="vm:LibraryViewModel">

  <Grid Margin="20"
        RowDefinitions="Auto,Auto,*"
        ColumnDefinitions="2*,3*"
        ColumnSpacing="16"
        RowSpacing="12">

    <!-- Encabezado -->
    <StackPanel Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Orientation="Horizontal"
                Spacing="10">
      <TextBlock Text="Biblioteca"
                 FontSize="28"
                 FontWeight="Bold"/>
      <Button Content="Importar carpeta"
              Command="{Binding ImportFolderCommand}"/>
    </StackPanel>

    <!-- Mensaje de estado -->
    <TextBlock Grid.Row="1"
               Grid.Column="0"
               Grid.ColumnSpan="2"
               Text="{Binding StatusMessage}"
               TextWrapping="Wrap"/>

    <!-- Lista izquierda -->
    <Border Grid.Row="2"
            Grid.Column="0"
            BorderBrush="Gray"
            BorderThickness="1"
            Padding="8">
      <ListBox ItemsSource="{Binding MediaItems}"
               SelectedItem="{Binding SelectedMedia, Mode=TwoWay}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="10"
                    Margin="4">
              <StackPanel>
                <TextBlock Text="{Binding Title}"
                           FontWeight="Bold"/>
                <TextBlock Text="{Binding FilePath}"
                           FontSize="12"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>

    <!-- Panel derecho -->
    <Border Grid.Row="2"
            Grid.Column="1"
            BorderBrush="Gray"
            BorderThickness="1"
            Padding="12">
      <Grid>

        <!-- Estado vacío -->
        <StackPanel IsVisible="{Binding HasNoSelectedMedia}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="10">
          <TextBlock Text="Selecciona un medio de la biblioteca para comenzar."
                     FontSize="14"
                     Opacity="0.7"
                     TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Estado con selección -->
        <ScrollViewer IsVisible="{Binding HasSelectedMedia}"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <Grid RowDefinitions="Auto,*,Auto"
                RowSpacing="12">

            <!-- Encabezado del medio seleccionado -->
            <StackPanel Grid.Row="0"
                        Spacing="4">
              <TextBlock Text="{Binding SelectedMediaTitle}"
                         FontSize="22"
                         FontWeight="Bold"
                         TextWrapping="Wrap"/>

              <TextBlock Text="{Binding SelectedMediaFolderPath}"
                         Opacity="0.75"
                         TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Reproductor -->
            <controls:MediaPlayerView Grid.Row="1"
                                      DataContext="{Binding MediaPlayerViewModel}"/>

            <!-- Notas -->
            <controls:NotesPanelView Grid.Row="2"/>

          </Grid>
        </ScrollViewer>

      </Grid>
    </Border>

  </Grid>
</UserControl>