<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:Tempovium.Views"
        xmlns:vm="using:Tempovium.ViewModels"
        x:Class="Tempovium.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Tempovium"
        Width="900"
        Height="600">

    <Window.DataTemplates>
        <DataTemplate DataType="vm:LoginViewModel">
            <views:LoginView />
        </DataTemplate>

        <DataTemplate DataType="vm:LibraryViewModel">
            <views:LibraryView />
        </DataTemplate>
    </Window.DataTemplates>

    <ContentControl Content="{Binding NavigationService.CurrentView}" />

</Window>