<UserControl
    x:Class="Tempovium.Controls.MediaPlayerView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Tempovium.ViewModels"
    xmlns:mac="clr-namespace:Tempovium.Media.Mac;assembly=Tempovium.Media.Mac"
    x:DataType="vm:MediaPlayerViewModel">

    <Border BorderBrush="White" BorderThickness="1" Padding="12">
        <StackPanel Spacing="12">

            <StackPanel Spacing="2">
                <TextBlock
                    FontSize="18"
                    FontWeight="Bold"
                    Text="{Binding CurrentMediaTitle}" />

                <TextBlock
                    Opacity="0.85"
                    Text="{Binding CurrentMediaPath}"
                    TextWrapping="Wrap" />

                <TextBlock
                    Opacity="0.75"
                    Text="{Binding CurrentMediaType}" />
            </StackPanel>

            <TextBlock
                FontSize="12"
                Opacity="0.7"
                Text="{Binding BackendStatus}" />

            <Border BorderBrush="White" BorderThickness="1" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="16"
                        FontWeight="Bold"
                        Text="Panel de reproducción" />

                    <!-- Estado vacío -->
                    <Border
                        Height="320"
                        BorderBrush="White"
                        BorderThickness="1"
                        IsVisible="{Binding HasNoSelectedMedia}">
                        <Grid>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Opacity="0.7"
                                Text="Selecciona un medio para comenzar." />
                        </Grid>
                    </Border>

                    <!-- Vista de video -->
                    <Border
                        Height="320"
                        BorderBrush="White"
                        BorderThickness="1"
                        IsVisible="{Binding IsVideo}">
                        <Grid>
                            <mac:MacVideoHost x:Name="NativeVideoHost" />

                            <Border
                                Background="#99000000"
                                IsVisible="{Binding IsLoading}">
                                <Grid
                                    RowDefinitions="Auto,Auto"
                                    RowSpacing="10"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                                    <ProgressBar
                                        Width="220"
                                        IsIndeterminate="True" />

                                    <TextBlock
                                        Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        Text="{Binding PlayerStatusText}" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Vista de audio -->
                    <Border
                        Height="320"
                        BorderBrush="White"
                        BorderThickness="1"
                        IsVisible="{Binding IsAudio}">
                        <Grid RowDefinitions="*,Auto,Auto"
                              Margin="24">

                            <StackPanel
                                Grid.Row="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="18">

                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="56"
                                    Text="♪" />

                                <StackPanel
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="8">

                                    <Border Width="10" Height="50" Background="White" CornerRadius="5" Opacity="0.85"/>
                                    <Border Width="10" Height="80" Background="White" CornerRadius="5" Opacity="0.85"/>
                                    <Border Width="10" Height="35" Background="White" CornerRadius="5" Opacity="0.85"/>
                                    <Border Width="10" Height="95" Background="White" CornerRadius="5" Opacity="0.85"/>
                                    <Border Width="10" Height="60" Background="White" CornerRadius="5" Opacity="0.85"/>
                                    <Border Width="10" Height="90" Background="White" CornerRadius="5" Opacity="0.85"/>
                                    <Border Width="10" Height="40" Background="White" CornerRadius="5" Opacity="0.85"/>
                                    <Border Width="10" Height="75" Background="White" CornerRadius="5" Opacity="0.85"/>
                                    <Border Width="10" Height="55" Background="White" CornerRadius="5" Opacity="0.85"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock
                                Grid.Row="1"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,12"
                                Text="{Binding PlayerStatusText}" />

                            <StackPanel
                                Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Spacing="12">

                                <Button
                                    Width="90"
                                    Content="Play"
                                    Command="{Binding PlayCommand}" />

                                <Button
                                    Width="90"
                                    Content="Pause"
                                    Command="{Binding PauseCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Separator />

                    <TextBlock
                        FontWeight="SemiBold"
                        Text="{Binding PlayerStatusText}" />

                    <StackPanel Spacing="6">
                        <TextBlock
                            FontSize="16"
                            FontWeight="Bold"
                            Text="Timeline" />

                        <Slider
                            x:Name="TimelineSlider"
                            Minimum="0"
                            Maximum="{Binding DurationSeconds, Mode=OneWay}"
                            Value="{Binding PositionSeconds, Mode=OneWay}"
                            PointerReleased="OnTimelineSliderPointerReleased" />

                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock
                                Opacity="0.75"
                                Text="{Binding PositionSeconds, StringFormat='Posición: {0:F2}s'}" />

                            <TextBlock
                                Grid.Column="1"
                                Opacity="0.75"
                                Text="{Binding DurationSeconds, StringFormat='Duración: {0:F2}s'}" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>