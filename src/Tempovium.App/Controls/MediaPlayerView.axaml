<UserControl
    x:Class="Tempovium.Controls.MediaPlayerView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Tempovium.ViewModels"
    xmlns:mac="clr-namespace:Tempovium.Media.Mac;assembly=Tempovium.Media.Mac"
    x:DataType="vm:MediaPlayerViewModel">

    <Border BorderBrush="White" BorderThickness="1" Padding="12">
        <StackPanel Spacing="12">

            <StackPanel Spacing="2">
                <TextBlock
                    FontSize="18"
                    FontWeight="Bold"
                    Text="{Binding CurrentMediaTitle}" />

                <TextBlock
                    Opacity="0.85"
                    Text="{Binding CurrentMediaPath}"
                    TextWrapping="Wrap" />

                <TextBlock
                    Opacity="0.75"
                    Text="{Binding CurrentMediaType}" />
            </StackPanel>

            <TextBlock
                FontSize="12"
                Opacity="0.7"
                Text="{Binding BackendStatus}" />

            <Border BorderBrush="White" BorderThickness="1" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="16"
                        FontWeight="Bold"
                        Text="Panel de reproducción" />

                    <Border
                        Height="320"
                        BorderBrush="White"
                        BorderThickness="1"
                        IsVisible="{Binding HasNoSelectedMedia}">
                        <Grid>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Opacity="0.7"
                                Text="Selecciona un medio para comenzar." />
                        </Grid>
                    </Border>

                    <Border
                        Height="320"
                        BorderBrush="White"
                        BorderThickness="1"
                        IsVisible="{Binding HasSelectedMedia}">
                        <Grid>
                            <mac:MacVideoHost x:Name="NativeVideoHost" />

                            <Border
                                Background="#99000000"
                                IsVisible="{Binding IsLoading}">
                                <Grid
                                    RowDefinitions="Auto,Auto"
                                    RowSpacing="10"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                                    <ProgressBar
                                        Width="220"
                                        IsIndeterminate="True" />

                                    <TextBlock
                                        Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        Text="{Binding PlayerStatusText}" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Separator />

                    <TextBlock
                        FontWeight="SemiBold"
                        Text="{Binding PlayerStatusText}" />

                    <StackPanel Spacing="6">
                        <TextBlock
                            FontSize="16"
                            FontWeight="Bold"
                            Text="Timeline" />

                        <Slider
                            Minimum="0"
                            Maximum="{Binding DurationSeconds, Mode=OneWay}"
                            Value="{Binding PositionSeconds, Mode=OneWay}" />

                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock
                                Opacity="0.75"
                                Text="{Binding PositionSeconds, StringFormat='Posición: {0:F2}s'}" />

                            <TextBlock
                                Grid.Column="1"
                                Opacity="0.75"
                                Text="{Binding DurationSeconds, StringFormat='Duración: {0:F2}s'}" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>