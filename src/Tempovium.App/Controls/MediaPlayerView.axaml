<UserControl
    x:Class="Tempovium.Controls.MediaPlayerView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Tempovium.ViewModels"
    xmlns:mac="clr-namespace:Tempovium.Media.Mac;assembly=Tempovium.Media.Mac"
    x:DataType="vm:MediaPlayerViewModel">

    <Border BorderBrush="White" BorderThickness="1" Padding="12">
        <StackPanel Spacing="12">

            <StackPanel Spacing="2">
                <TextBlock
                    FontSize="18"
                    FontWeight="Bold"
                    Text="{Binding CurrentMediaTitle}" />

                <TextBlock
                    Opacity="0.85"
                    Text="{Binding CurrentMediaPath}"
                    TextWrapping="Wrap" />

                <TextBlock
                    Opacity="0.75"
                    Text="{Binding CurrentMediaType}" />
            </StackPanel>

            <TextBlock
                FontSize="12"
                Opacity="0.7"
                Text="{Binding BackendStatus}" />

            <Border BorderBrush="White" BorderThickness="1" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="16"
                        FontWeight="Bold"
                        Text="Panel de reproducción" />

                    <Border
                        Height="320"
                        BorderBrush="White"
                        BorderThickness="1"
                        IsVisible="{Binding HasNoSelectedMedia}">
                        <Grid>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Opacity="0.7"
                                Text="Selecciona un medio para comenzar." />
                        </Grid>
                    </Border>

                    <Border
                        Height="320"
                        BorderBrush="White"
                        BorderThickness="1"
                        IsVisible="{Binding IsVideo}">
                        <Grid>
                            <mac:MacVideoHost
                                x:Name="NativeVideoHost"
                                Backend="{Binding MacBackend}" />

                            <Border
                                Background="#99000000"
                                IsVisible="{Binding IsLoading}">
                                <Grid
                                    RowDefinitions="Auto,Auto"
                                    RowSpacing="10"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                                    <ProgressBar
                                        Width="220"
                                        IsIndeterminate="True" />

                                    <TextBlock
                                        Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        Text="{Binding PlayerStatusText}" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border
                        Height="360"
                        BorderBrush="White"
                        BorderThickness="1"
                        IsVisible="{Binding IsAudio}">
                        <Grid
                            Margin="20"
                            RowDefinitions="Auto,Auto,Auto,*,Auto"
                            RowSpacing="16">

                            <TextBlock
                                Grid.Row="0"
                                HorizontalAlignment="Center"
                                Margin="0,6,0,0"
                                FontSize="56"
                                Text="♪" />

                            <Border
                                Grid.Row="1"
                                Width="340"
                                Height="110"
                                HorizontalAlignment="Center"
                                Padding="18,14"
                                CornerRadius="18"
                                BorderBrush="#55FFFFFF"
                                BorderThickness="1">
                                <StackPanel
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="8">

                                    <Border Width="12" Height="44" Background="White" CornerRadius="12" Opacity="0.85"/>
                                    <Border Width="12" Height="68" Background="White" CornerRadius="12" Opacity="0.85"/>
                                    <Border Width="12" Height="34" Background="White" CornerRadius="12" Opacity="0.85"/>
                                    <Border Width="12" Height="82" Background="White" CornerRadius="12" Opacity="0.85"/>
                                    <Border Width="12" Height="56" Background="White" CornerRadius="12" Opacity="0.85"/>
                                    <Border Width="12" Height="78" Background="White" CornerRadius="12" Opacity="0.85"/>
                                    <Border Width="12" Height="40" Background="White" CornerRadius="12" Opacity="0.85"/>
                                    <Border Width="12" Height="64" Background="White" CornerRadius="12" Opacity="0.85"/>
                                    <Border Width="12" Height="50" Background="White" CornerRadius="12" Opacity="0.85"/>
                                </StackPanel>
                            </Border>

                            <TextBlock
                                Grid.Row="2"
                                HorizontalAlignment="Center"
                                Text="{Binding PlayerStatusText}" />

                            <StackPanel
                                Grid.Row="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Spacing="12">

                                <Button
                                    Width="90"
                                    Content="Play"
                                    Command="{Binding PlayCommand}" />

                                <Button
                                    Width="90"
                                    Content="Pause"
                                    Command="{Binding PauseCommand}" />
                            </StackPanel>

                            <Border
                                Grid.Row="4"
                                Margin="0,4,0,0"
                                Padding="0,10,0,0">
                                <Grid
                                    RowDefinitions="Auto,Auto"
                                    RowSpacing="10">

                                    <TextBlock
                                        Grid.Row="0"
                                        HorizontalAlignment="Center"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Text="Timeline" />

                                    <Grid
                                        Grid.Row="1"
                                        ColumnDefinitions="Auto,Auto,*,Auto"
                                        ColumnSpacing="12"
                                        VerticalAlignment="Center">

                                        <Button
                                            Width="90"
                                            Content="Play"
                                            Command="{Binding PlayCommand}"
                                            IsVisible="{Binding IsPaused}"
                                            VerticalAlignment="Center" />

                                        <Button
                                            Width="90"
                                            Content="Pause"
                                            Command="{Binding PauseCommand}"
                                            IsVisible="{Binding IsPlaying}"
                                            VerticalAlignment="Center" />

                                        <TextBlock
                                            Grid.Column="1"
                                            MinWidth="95"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"
                                            Opacity="0.75"
                                            Text="{Binding PositionSeconds, StringFormat='Posición: {0:F2}s'}" />

                                        <Slider
                                            x:Name="TimelineSlider"
                                            Grid.Column="2"
                                            Minimum="0"
                                            Maximum="{Binding DurationSeconds, Mode=OneWay}"
                                            Value="{Binding PositionSeconds, Mode=OneWay}"
                                            PointerReleased="OnTimelineSliderPointerReleased"
                                            VerticalAlignment="Center" />

                                        <TextBlock
                                            Grid.Column="3"
                                            MinWidth="110"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"
                                            Opacity="0.75"
                                            Text="{Binding DurationSeconds, StringFormat='Duración: {0:F2}s'}" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>