<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tempovium.ViewModels"
             xmlns:converters="using:Tempovium.Converters"
             x:Class="Tempovium.Controls.MediaPlayerView"
             x:DataType="vm:MediaPlayerViewModel">

  <UserControl.Resources>
    <converters:SecondsToTimestampConverter x:Key="SecondsToTimestampConverter"/>
  </UserControl.Resources>

  <Border BorderBrush="Gray"
          BorderThickness="1"
          Padding="16"
          MinHeight="360">

    <Grid RowDefinitions="Auto,*,Auto"
          RowSpacing="12">

      <!-- Encabezado del reproductor -->
      <StackPanel Grid.Row="0"
                  Spacing="4">
        <TextBlock Text="Panel de reproducción"
                   FontSize="16"
                   FontWeight="Bold"/>

        <TextBlock Text="{Binding BackendStatus}"
                   Opacity="0.7"/>
      </StackPanel>

      <!-- Área de video -->
      <Border Grid.Row="1"
              BorderBrush="DarkGray"
              BorderThickness="1"
              Background="Black"
              MinHeight="300">

        <Grid>

          <StackPanel IsVisible="{Binding IsLoading}"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Spacing="10">
            <ProgressBar IsIndeterminate="True"
                         Width="180"/>
            <TextBlock Text="Preparando reproductor..."
                       HorizontalAlignment="Center"
                       Opacity="0.7"/>
          </StackPanel>
        </Grid>

      </Border>

      <!-- Estado + timeline -->
      <StackPanel Grid.Row="2"
                  Spacing="8">
        <TextBlock Text="{Binding PlayerStatusText}"
                   Opacity="0.7"/>

        <Separator/>

        <TextBlock Text="Timeline"
                   FontWeight="SemiBold"/>

        <Slider Minimum="0"
                Maximum="{Binding DurationSeconds}"
                Value="{Binding PositionSeconds}"
                IsEnabled="False"/>

        <Grid ColumnDefinitions="Auto,*,Auto">
          <TextBlock Text="{Binding PositionSeconds, Converter={StaticResource SecondsToTimestampConverter}}"
                     Opacity="0.7"/>

          <TextBlock Grid.Column="2"
                     Text="{Binding DurationSeconds, Converter={StaticResource SecondsToTimestampConverter}}"
                     Opacity="0.7"/>
        </Grid>
      </StackPanel>

    </Grid>

  </Border>
</UserControl>